{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 22,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Debug",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "OCTA_BUILD_AUDIO_PLUGIN_HOST": "ON"
      }
    },
    {
      "name": "release",
      "inherits": "base",
      "displayName": "Release",
      "generator": "Visual Studio 17 2022",
      "architecture": {
        "value": "x64",
        "strategy": "set"
      },
      "cacheVariables": {
        "OCTA_BUILD_AUDIO_PLUGIN_HOST": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug-standalone-app",
      "displayName": "Build app",
      "configurePreset": "debug",
      "configuration": "Debug",
      "targets": [
        "OctaChainer2_App"
      ]
    },
    {
      "name": "debug-vst-plugin",
      "displayName": "Build plugin",
      "configurePreset": "debug",
      "configuration": "Debug",
      "targets": [
        "AudioPluginHost"
      ]
    },
    {
      "name": "release-standalone-app",
      "displayName": "Build app",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "OctaChainer2_App"
      ]
    },
    {
      "name": "release-vst-plugin",
      "displayName": "Build plugin",
      "configurePreset": "release",
      "configuration": "Release",
      "targets": [
        "AudioPluginHost"
      ]
    }
  ]
}
